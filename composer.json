{
    "name": "xuongdientu/gdrive-manager",
    "description": "Google Drive File Manager with User Permissions",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "google/apiclient": "^2.15"
    },
    "require-dev": {},
    "autoload": {
        "psr-4": {
            "App\\": "includes/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
